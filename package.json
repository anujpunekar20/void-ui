{
  "name": "@anuj20/void-ui",
  "version": "0.1.0",
  "description": "Dark-first, minimalist React UI component library",
  "keywords": [
    "react",
    "ui",
    "component-library",
    "dark-theme",
    "typescript"
  ],
  "license": "MIT",
  "author": "Anuj Punekar",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anujpunekar20/void-ui.git"
  },
  "homepage": "https://anujpunekar20.github.io/void-ui/",
  "bugs": {
    "url": "https://github.com/anujpunekar20/void-ui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "vite build && node -e \"const fs=require('fs');const t=fs.existsSync('dist/style.css')?fs.readFileSync('dist/style.css','utf8'):'';const s=fs.existsSync('dist/assets/stylex.css')?fs.readFileSync('dist/assets/stylex.css','utf8'):'';fs.writeFileSync('dist/index.css',t+s);\"",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest",
    "prepublishOnly": "npm run build",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@floating-ui/react": "^0.26.0",
    "@stylexjs/stylex": "^0.19.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.0.0",
    "@storybook/react": "^8.0.0",
    "@storybook/react-vite": "^8.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "happy-dom": "^14.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "storybook": "^8.0.0",
    "typescript": "^5.4.0",
    "unplugin-stylex": "^0.6.3",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^2.0.0"
  }
}
